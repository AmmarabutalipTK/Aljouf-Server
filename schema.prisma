generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String

  role      Role     @default(USER)

  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  USER
}

model Ticket {
  id             Int      @id @default(autoincrement())

  category       Category
  status         Status?  @default(IN_PROGRESS)

  orderNumber    String?
  shipmentNumber String?

  customerName   String?
  phone          String?
  botPhone       String?

  title          String?
  description    String?

  operation      String?
  productType    String?
  quantity       Int?

  complaintStatus String?

  reason         String?
  subCategory    String?

  location       String?

  missingCount   Int?
  productNames   String?

  receivedGood   Boolean?

  imageUrl       String?

  aljoufNote     String?
  customerNote   String?
  itemStatus     String?

  complaintStatusUpdatedBy String?
  complaintStatusUpdatedAt DateTime?

  complaintSubmittedAt DateTime?

  notes TicketNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TicketNote {
  id Int @id @default(autoincrement())

  ticketId Int
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  username String
  message String

  createdAt DateTime @default(now())
}

enum Category {
  COMPLAINT
  ORDER_MODIFICATION
  ORDER_CANCELLATION
  RETURN_REPLACEMENT
  ORDER_DELAY_ERROR
}

enum Status {
  NEW
  CONTACTED
  IN_PROGRESS
  PENDING_CUSTOMER
  RESOLVED
  CLOSED
}